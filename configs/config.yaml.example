# OKX 量化交易系统配置文件示例

basic:
  app_name: "okx-quant"
  env: "development"
  log_level: "info"
  log_file: "./logs/okx-quant.log"

exchange:
  okx:
    api_key: "${OKX_API_KEY}"
    secret_key: "${OKX_SECRET_KEY}"
    passphrase: "${OKX_PASSPHRASE}"
    base_url: "https://www.okx.com"
    ws_url: "wss://ws.okx.com:8443/ws/v5/public"
    timeout: 30s
    retry_count: 3
    simulated: true

risk:
  enable: true
  max_position_size: 10000
  max_daily_loss: 500
  max_drawdown: 0.1
  stop_loss_percent: 0.02
  take_profit_percent: 0.05
  max_trades_per_day: 100

execution:
  enable_strategy_take_profit: true
  persistence:
    enabled: true
    directory: "./data/runtime"
    snapshot_interval: 30s
  smart_routing:
    order_book_depth: 20
    max_estimated_slippage: 0.0025
  rebalance:
    enabled: true
    reduce_only: true
    drift_threshold: 0.1
    use_market_orders: true
    max_positions_per_cycle: 2
    circuit_auto_reset: true
    circuit_cooldown: 15m
  allocator:
    min_weight: 0.1
    max_weight: 0.7
    weight_change_threshold: 0.15
    cooldown_duration: 24h
    rebalance_interval: 4h
    portfolio_loss_limit: 0.05

backtest:
  enable: false
  initial_balance: 10000
  data_dir: "./data"
  result_dir: "./results"

monitoring:
  enable: true
  check_interval: 30s
  alert_threshold:
    max_drawdown: 0.15
    max_loss: 500
    position_limit: 10000
    order_timeout: 5m
  metrics:
    enable: true
    push_gateway_url: ""
  alert:
    enable: true
    channels:
      - "console"
    webhook_url: "${WEBHOOK_URL}"
    dedup_window: 30s
    min_interval: 10s

strategy:
  enable: false
  name: "example_strategy"
  params: {}
  delta_neutral:
    fund_usage_percent: 0.9
    rebalance_threshold: 0.02
    basis_circuit_breaker: 0.01
    target_hedge_ratio: 1.0
    hedge_ratio_tolerance: 0.05
    daily_loss_limit: 0.02
    margin_buffer_percent: 0.1
    settlement_window_before: 30m
    settlement_window_after: 30m

server:
  enable: true
  host: "127.0.0.1"
  port: 8765
